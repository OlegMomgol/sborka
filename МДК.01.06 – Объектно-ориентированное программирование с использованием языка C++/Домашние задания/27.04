#include <iostream>
#include <string>
#include <vector>

using namespace std;

class Notification {
public:

    virtual void send() = 0;

    virtual ~Notification() {}
};

class EmailNotification : public Notification {
private:
    string email;
    string message;
    
public:
    EmailNotification(const string& email, const string& message) 
        : email(email), message(message) {}
    
    void send() override {
        cout << "   Отправка Email на " << email << endl;
        cout << "   Сообщение: " << message << endl;
        cout << "   Статус: Успешно отправлено" << endl;
        cout << endl;
    }
};

class SMSNotification : public Notification {
private:
    string phoneNumber;
    string message;
    
public:
    SMSNotification(const string& phoneNumber, const string& message)
        : phoneNumber(phoneNumber), message(message) {}
    
    void send() override {
        cout << "   Отправка SMS на номер " << phoneNumber << endl;
        cout << "   Сообщение: " << message << endl;
        cout << "   Статус: Успешно отправлено" << endl;
        cout << endl;
    }
};

class PushNotification : public Notification {
private:
    string deviceId;
    string title;
    string message;
    
public:
    PushNotification(const string& deviceId, const string& title, const string& message)
        : deviceId(deviceId), title(title), message(message) {}
    
    void send() override {
        cout << "  Отправка Push-уведомления на устройство " << deviceId << endl;
        cout << "   Заголовок: " << title << endl;
        cout << "   Сообщение: " << message << endl;
        cout << "   Статус: Успешно отправлено" << endl;
        cout << endl;
    }
};

void sendNotifications(vector<Notification*>& notifications) {
    for (auto notification : notifications) {
        notification->send();
    }
}

int main() {
    EmailNotification email("user@example.com", "Ваш заказ подтвержден");
    SMSNotification sms("+7 (999) 123-45-67", "Код подтверждения: 123456");
    PushNotification push("device_789", "Новое сообщение", "У вас новое сообщение от друга");

    cout << " Демонстрация работы системы уведомлений \n" << endl;
    
    Notification* notif1 = &email;
    Notification* notif2 = &sms;
    Notification* notif3 = &push;
    
    notif1->send();
    notif2->send();
    notif3->send();
  
    cout << " Массовая рассылка уведомлений \n" << endl;
    
    vector<Notification*> notifications;
    notifications.push_back(new EmailNotification("admin@site.com", "Новый пользователь зарегистрировался"));
    notifications.push_back(new SMSNotification("+7 (111) 222-33-44", "Ваш баланс пополнен"));
    notifications.push_back(new PushNotification("tablet_456", "Обновление", "Доступна новая версия приложения"));
    
    sendNotifications(notifications);

    for (auto notif : notifications) {
        delete notif;
    }
    
    return 0;
}

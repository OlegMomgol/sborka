// 1 
#include <iostream>
#include <string>
using namespace std;

class Book {
private:
    string title;
    int pages;
    
public:
    Book() {
        title = "Неизвестно";
        pages = 0;
        cout << "Вызван конструктор по умолчанию" << endl;
    }

    Book(string t, int p) {
        title = t;
        pages = p;
        cout << "Вызван параметризованный конструктор" << endl;
    }

    void displayInfo() {
        cout << "Название книги: " << title << endl;
        cout << "Количество страниц: " << pages << endl;
    }
};

int main() {
    cout << " Демонстрация работы класса Book " << endl;

    Book book1;
    book1.displayInfo();

    Book book2("Война и мир", 1300);
    book2.displayInfo();
    
    Book book3("Преступление и наказание", 672);
    book3.displayInfo();
    
    return 0;
}

// 2 
#include <iostream>
using namespace std;

class DynamicBuffer {
private:
    int* arr;       
    int size;     
    
public:
    DynamicBuffer(int n) {
        size = n;
        arr = new int[size];
        cout << "Выделено " << size << " элементов памяти" << endl;

        for (int i = 0; i < size; i++) {
            arr[i] = 0;
        }
    }

    ~DynamicBuffer() {
        delete[] arr;
        cout << "Память освобождена" << endl;
    }

    void fillArray() {
        cout << "Введите " << size << " целых чисел:" << endl;
        for (int i = 0; i < size; i++) {
            cout << "Элемент " << i + 1 << ": ";
            cin >> arr[i];
        }
    }

    void displayArray() {
        cout << "Массив: ";
        for (int i = 0; i < size; i++) {
            cout << arr[i] << " ";
        }
        cout << endl;
    }
};

int main() {
    cout << " Демонстрация работы класса DynamicBuffer " << endl;
    
    int arraySize;
    cout << "Введите размер массива: ";
    cin >> arraySize;

    DynamicBuffer buffer(arraySize);
    buffer.fillArray();
    buffer.displayArray();
    cout << "Завершение работы программы" << endl;
    return 0;
}

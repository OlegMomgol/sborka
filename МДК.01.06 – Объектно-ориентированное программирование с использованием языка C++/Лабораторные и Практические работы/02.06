#include <iostream>
#include <fstream>
#include <string>
#include <map>

bool isInfo(const std::string& line) {
    return line.find("INFO:") == 0;
}

bool isWarning(const std::string& line) {
    return line.find("WARNING:") == 0;
}

bool isError(const std::string& line) {
    return line.find("ERROR:") == 0;
}

std::string extractMessage(const std::string& line) {
    size_t colonPos = line.find(':');
    if (colonPos != std::string::npos) {
        return line.substr(colonPos + 1); // Пропускаем ": "
    }
    return line;
}

int main() {
    std::ifstream file("log.txt");
    
    if (!file.is_open()) {
        std::cerr << "Ошибка: Не удалось открыть файл log.txt" << std::endl;
        return 1;
    }
    
    std::map<std::string, int> stats = {
        {"INFO", 0},
        {"WARNING", 0},
        {"ERROR", 0}
    };
    
    std::string line;
    std::string errors;

    while (std::getline(file, line)) {
        if (isInfo(line)) {
            stats["INFO"]++;
        } else if (isWarning(line)) {
            stats["WARNING"]++;
        } else if (isError(line)) {
            stats["ERROR"]++;
            errors += "ERROR:" + extractMessage(line) + " ";
        }
    }
    
    file.close();
    
    std::cout << "Статистика: "
              << "INFO: " << stats["INFO"] << " "
              << "WARNING: " << stats["WARNING"] << " "
              << "ERROR: " << stats["ERROR"] << std::endl;
    
    if (!errors.empty()) {
        std::cout << "Ошибки: " << errors << std::endl;
    }
    
    return 0;
}

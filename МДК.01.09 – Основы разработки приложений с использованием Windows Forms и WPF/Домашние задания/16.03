// 1 
DrawSquare(5, '*');
DrawSquare(3, '#');
static void DrawSquare(int sideLength, char symbol)
{
    for (int i = 0; i < sideLength; i++)
    {
        for (int j = 0; j < sideLength; j++)
        {
            Console.Write(symbol);
        }
        Console.WriteLine();
    }
    Console.WriteLine();
}

// 2
Console.WriteLine($"1221 -> {IsPalindrome(1221)}");
Console.WriteLine($"3443 -> {IsPalindrome(3443)}");
Console.WriteLine($"7854 -> {IsPalindrome(7854)}");
Console.WriteLine($"12321 -> {IsPalindrome(12321)}");
static bool IsPalindrome(int number)
{
    string str = number.ToString();
    for (int i = 0; i < str.Length / 2; i++)
    {
        if (str[i] != str[str.Length - 1 - i])
        {
            return false;
        }
    }
    return true;
}

Console.WriteLine();

// 3 
int[] originalArray = { 1, 2, 6, -1, 88, 7, 6 };
int[] filterArray = { 6, 88, 7 };

Console.WriteLine("Оригинальный массив: " + string.Join(", ", originalArray));
Console.WriteLine("Массив для фильтрации: " + string.Join(", ", filterArray));

int[] result = FilterArray(originalArray, filterArray);
Console.WriteLine("Результат: " + string.Join(", ", result));
static int[] FilterArray(int[] original, int[] filter)
{
    List<int> resultList = new List<int>();

    foreach (int item in original)
    {
        bool found = false;
        foreach (int filterItem in filter)
        {
            if (item == filterItem)
            {
                found = true;
                break;
            }
        }
        if (!found)
        {
            resultList.Add(item);
        }
    }

    return resultList.ToArray();
}


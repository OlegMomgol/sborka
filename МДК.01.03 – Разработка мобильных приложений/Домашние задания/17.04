import 'dart:ui' as ui;
import 'package:flutter/material.dart';

Future<ui.Image> generateCertificateImage({
  required String studentName,
  required String courseName,
  required String teacherName,
  required double width,
  required double height,
}) async {
  final recorder = ui.PictureRecorder();
  final canvas = Canvas(recorder);

  final paint = Paint()..color = Colors.white;
  canvas.drawRect(Rect.fromLTWH(0, 0, width, height), paint);

  final borderPaint = Paint()
    ..color = Colors.grey.shade300
    ..style = PaintingStyle.stroke
    ..strokeWidth = 4;
  canvas.drawRect(Rect.fromLTWH(20, 20, width - 40, height - 40), borderPaint);

  final innerBorderPaint = Paint()
    ..color = Colors.grey.shade200
    ..style = PaintingStyle.stroke
    ..strokeWidth = 2;
  canvas.drawRect(Rect.fromLTWH(25, 25, width - 50, height - 50), innerBorderPaint);
  
  final titleStyle = TextStyle(
    fontSize: 48,
    fontWeight: FontWeight.bold,
    color: Colors.brown.shade700,
    letterSpacing: 4,
  );
  final titleTP = TextPainter(
    text: TextSpan(text: 'ГРАМОТА', style: titleStyle),
    textAlign: TextAlign.center,
    textDirection: TextDirection.ltr,
  );
  titleTP.layout(maxWidth: width - 80);
  titleTP.paint(canvas, Offset((width - titleTP.width) / 2, 80));
  final subtitleStyle = TextStyle(
    fontSize: 24,
    color: Colors.grey.shade700,
    letterSpacing: 2,
  );
  final subtitleTP = TextPainter(
    text: TextSpan(text: 'НАГРАЖДАЕТСЯ', style: subtitleStyle),
    textAlign: TextAlign.center,
    textDirection: TextDirection.ltr,
  );
  subtitleTP.layout(maxWidth: width - 80);
  subtitleTP.paint(canvas, Offset((width - subtitleTP.width) / 2, 150));
  
  final nameStyle = TextStyle(
    fontSize: 42,
    fontWeight: FontWeight.bold,
    color: Colors.blue.shade800,
    letterSpacing: 2,
  );
  final nameTP = TextPainter(
    text: TextSpan(text: studentName, style: nameStyle),
    textAlign: TextAlign.center,
    textDirection: TextDirection.ltr,
  );
  nameTP.layout(maxWidth: width - 100);
  nameTP.paint(canvas, Offset((width - nameTP.width) / 2, 230));
  
  final completionStyle = TextStyle(
    fontSize: 20,
    color: Colors.grey.shade800,
  );
  final completionTP = TextPainter(
    text: TextSpan(text: 'за успешное завершение курса', style: completionStyle),
    textAlign: TextAlign.center,
    textDirection: TextDirection.ltr,
  );
  completionTP.layout(maxWidth: width - 80);
  completionTP.paint(canvas, Offset((width - completionTP.width) / 2, 310));
  
  final courseStyle = TextStyle(
    fontSize: 32,
    fontWeight: FontWeight.w600,
    color: Colors.green.shade700,
    fontStyle: FontStyle.italic,
  );
  final courseTP = TextPainter(
    text: TextSpan(text: courseName, style: courseStyle),
    textAlign: TextAlign.center,
    textDirection: TextDirection.ltr,
  );
  courseTP.layout(maxWidth: width - 100);
  courseTP.paint(canvas, Offset((width - courseTP.width) / 2, 360));
  
  // Подпись учителя
  final teacherStyle = TextStyle(
    fontSize: 18,
    color: Colors.grey.shade700,
  );
  final teacherLabelTP = TextPainter(
    text: TextSpan(text: 'Преподаватель:', style: teacherStyle),
    textAlign: TextAlign.center,
    textDirection: TextDirection.ltr,
  );
  teacherLabelTP.layout(maxWidth: width - 80);
  teacherLabelTP.paint(canvas, Offset((width - teacherLabelTP.width) / 2, 440));
  
  final teacherNameStyle = TextStyle(
    fontSize: 20,
    fontWeight: FontWeight.w500,
    color: Colors.grey.shade800,
  );
  final teacherNameTP = TextPainter(
    text: TextSpan(text: teacherName, style: teacherNameStyle),
    textAlign: TextAlign.center,
    textDirection: TextDirection.ltr,
  );
  teacherNameTP.layout(maxWidth: width - 80);
  teacherNameTP.paint(canvas, Offset((width - teacherNameTP.width) / 2, 475));
  
  final linePaint = Paint()
    ..color = Colors.grey.shade400
    ..strokeWidth = 1;
  canvas.drawLine(
    Offset(width / 2 - 80, 510),
    Offset(width / 2 + 80, 510),
    linePaint,
  );
  
  final now = DateTime.now();
  final months = [
    'января', 'февраля', 'марта', 'апреля', 'мая', 'июня',
    'июля', 'августа', 'сентября', 'октября', 'ноября', 'декабря'
  ];
  final dateStr = '${now.day} ${months[now.month - 1]} ${now.year}';
  
  final dateStyle = TextStyle(
    fontSize: 14,
    color: const Color(0xFF9E9E9E),
  );
  final dateTP = TextPainter(
    text: TextSpan(text: dateStr, style: dateStyle),
    textAlign: TextAlign.center,
    textDirection: TextDirection.ltr,
  );
  dateTP.layout(maxWidth: width - 80);
  dateTP.paint(canvas, Offset((width - dateTP.width) / 2, height - 40));
  
  final picture = recorder.endRecording();
  final image = await picture.toImage(width.toInt(), height.toInt());
  
  return image;
}

class CertificateWidget extends StatelessWidget {
  final String studentName;
  final String courseName;
  final String teacherName;
  
  const CertificateWidget({
    Key? key,
    required this.studentName,
    required this.courseName,
    required this.teacherName,
  }) : super(key: key);
  
  @override
  Widget build(BuildContext context) {
    return FutureBuilder<ui.Image>(
      future: generateCertificateImage(
        studentName: studentName,
        courseName: courseName,
        teacherName: teacherName,
        width: 800,
        height: 600,
      ),
      builder: (context, snapshot) {
        if (snapshot.hasData) {
          return RawImage(
            image: snapshot.data,
            width: 800,
            height: 600,
          );
        }
        return const Center(child: CircularProgressIndicator());
      },
    );
  }
}
